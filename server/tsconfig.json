{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../dist/server",
    "rootDir": "..",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["node", "vite/client"],
    "jsx": "react-jsx",
    "baseUrl": "..",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "../src/lib/workbench/**/*.ts",
    "../src/lib/workbench/**/*.tsx",
    "../src/components/workbench-boxes/**/*.ts",
    "../src/components/workbench-boxes/**/*.tsx",
    "../src/components/customization/utility-widgets.tsx"
  ]
}
