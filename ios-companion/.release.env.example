# Copy this file to `.release.env` and fill it once for local releases.
#
# App Store Connect API key auth is the only supported scripted auth path.
# You can provide either a path to the `.p8` file or a base64-encoded key body.

FORGE_ASC_KEY_ID=REPLACE_WITH_ASC_KEY_ID
FORGE_ASC_ISSUER_ID=REPLACE_WITH_ASC_ISSUER_ID
FORGE_ASC_KEY_PATH=/absolute/path/to/AuthKey_REPLACE_WITH_KEY_ID.p8
# FORGE_ASC_KEY_CONTENT_BASE64=REPLACE_WITH_BASE64_P8_CONTENT

# Optional overrides.
FORGE_APPLE_TEAM_ID=KZ65F7924F
FORGE_RELEASE_SKIP_REMOTE_VALIDATION=0
