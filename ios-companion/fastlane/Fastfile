default_platform(:ios)

require "json"
require "yaml"
require "base64"
require "cfpropertylist"
require "fileutils"
require "shellwords"

platform :ios do
  before_all do |_lane, _options|
    setup_ci if ENV["CI"] && ci_uses_fastlane_setup?
  end

  desc "Validate Forge Companion release inputs and produce a local archive without uploading"
  lane :validate_release do |options|
    config = load_release_config
    mode = normalized_release_mode(options[:mode] || "validate")
    metadata_state = validate_release_inputs!(config: config, mode: mode, require_api_key: false)
    artifact_dir = prepare_artifact_dir(options[:artifact_dir], mode: "validate")
    archive_path = File.join(artifact_dir, "ForgeCompanion.xcarchive")
    ipa_path = build_release_archive!(
      artifact_dir: artifact_dir,
      archive_path: archive_path,
      marketing_version: config.dig(:version, :marketing).to_s,
      bump_build_number: false
    )
    write_release_summary(
      artifact_dir: artifact_dir,
      mode: "validate",
      config: config,
      archive_path: archive_path,
      ipa_path: ipa_path,
      build_number: current_build_number,
      metadata_state: metadata_state,
      uploaded: false,
      submitted_for_review: false
    )
    UI.success("Validation archive complete at #{artifact_dir}")
  end

  desc "Archive and upload Forge Companion to TestFlight"
  lane :testflight_release do |options|
    config = load_release_config
    metadata_state = validate_release_inputs!(config: config, mode: "testflight", require_api_key: true)
    api_key = app_store_connect_api_key_from_env
    verify_app_store_connect_app!(config: config)
    artifact_dir = prepare_artifact_dir(options[:artifact_dir], mode: "testflight")
    archive_path = File.join(artifact_dir, "ForgeCompanion.xcarchive")
    increment_release_versions!(config)
    build_number = current_build_number
    ipa_path = build_release_archive!(
      artifact_dir: artifact_dir,
      archive_path: archive_path,
      marketing_version: config.dig(:version, :marketing).to_s,
      bump_build_number: false
    )
    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      changelog: release_notes_text(config),
      groups: Array(config.dig(:release, :testflight_groups)),
      notify_external_testers: config.dig(:release, :notify_external_testers) == true,
      skip_waiting_for_build_processing: true
    )
    write_release_summary(
      artifact_dir: artifact_dir,
      mode: "testflight",
      config: config,
      archive_path: archive_path,
      ipa_path: ipa_path,
      build_number: build_number,
      metadata_state: metadata_state,
      uploaded: true,
      submitted_for_review: false
    )
    UI.success("TestFlight upload complete at #{artifact_dir}")
  end

  desc "Archive, upload, and submit Forge Companion for App Store review"
  lane :app_store_release do |options|
    config = load_release_config
    metadata_state = validate_release_inputs!(config: config, mode: "app-store", require_api_key: true)
    api_key = app_store_connect_api_key_from_env
    verify_app_store_connect_app!(config: config)
    artifact_dir = prepare_artifact_dir(options[:artifact_dir], mode: "app-store")
    archive_path = File.join(artifact_dir, "ForgeCompanion.xcarchive")
    increment_release_versions!(config)
    build_number = current_build_number
    ipa_path = build_release_archive!(
      artifact_dir: artifact_dir,
      archive_path: archive_path,
      marketing_version: config.dig(:version, :marketing).to_s,
      bump_build_number: false
    )
    upload_to_app_store(
      api_key: api_key,
      app_identifier: config.dig(:app, :primary_bundle_id),
      ipa: ipa_path,
      metadata_path: metadata_root(config),
      screenshots_path: screenshots_root(config),
      skip_metadata: false,
      skip_screenshots: !metadata_state[:upload_screenshots],
      overwrite_screenshots: metadata_state[:upload_screenshots],
      submit_for_review: true,
      automatic_release: config.dig(:release, :automatic_release) == true,
      phased_release: config.dig(:release, :phased_release) == true,
      submission_information: {
        export_compliance_uses_encryption: false
      },
      precheck_include_in_app_purchases: false,
      force: true
    )
    write_release_summary(
      artifact_dir: artifact_dir,
      mode: "app-store",
      config: config,
      archive_path: archive_path,
      ipa_path: ipa_path,
      build_number: build_number,
      metadata_state: metadata_state,
      uploaded: true,
      submitted_for_review: true
    )
    UI.success("App Store submission complete at #{artifact_dir}")
  end
end

def release_root
  File.expand_path("..", __dir__)
end

def forge_root
  File.expand_path("..", release_root)
end

def xcode_project_path
  File.join(release_root, "ForgeCompanion.xcodeproj")
end

def scheme_name
  "ForgeCompanion"
end

def release_config_path
  ENV["FORGE_RELEASE_CONFIG_PATH"] || File.join(release_root, "release", "release.yml")
end

def load_release_config
  @load_release_config ||= begin
    UI.user_error!("Missing release config at #{release_config_path}") unless File.exist?(release_config_path)
    YAML.safe_load(File.read(release_config_path), aliases: false, symbolize_names: true)
  end
end

def metadata_root(config)
  File.join(release_root, config.dig(:metadata, :metadata_path) || "fastlane/metadata")
end

def screenshots_root(config)
  File.join(release_root, config.dig(:metadata, :screenshots_path) || "fastlane/screenshots")
end

def screenshots_manifest_path(config)
  File.join(release_root, config.dig(:metadata, :screenshots_manifest) || "fastlane/screenshots/manifest.json")
end

def default_locale(config)
  config.dig(:metadata, :default_locale) || "en-US"
end

def screenshot_source_locale(config)
  config.dig(:metadata, :screenshot_source_locale) || default_locale(config)
end

def screenshot_target_locales(config)
  configured = Array(config.dig(:metadata, :screenshot_locales)).map(&:to_s).map(&:strip).reject(&:empty?)
  return configured.uniq unless configured.empty?

  locales_from_metadata = Dir.children(metadata_root(config))
    .select { |entry| File.directory?(File.join(metadata_root(config), entry)) }
    .sort

  ([screenshot_source_locale(config)] + locales_from_metadata).uniq
end

def mirror_screenshots_for_locales!(config)
  source_locale = screenshot_source_locale(config)
  target_locales = screenshot_target_locales(config)
  manifest_path = screenshots_manifest_path(config)
  UI.user_error!("Missing screenshot manifest at #{manifest_path}") unless File.exist?(manifest_path)

  manifest = JSON.parse(File.read(manifest_path))
  source_files = Array(manifest["required_files"]).map(&:to_s).reject(&:empty?)
  UI.user_error!("Screenshot manifest #{manifest_path} has no required_files entries") if source_files.empty?

  source_files.each do |relative_path|
    unless relative_path.start_with?("#{source_locale}/")
      UI.user_error!("Screenshot manifest entry #{relative_path} must live under the source locale #{source_locale}")
    end
  end

  target_locales.each do |locale|
    source_files.each do |relative_path|
      locale_relative_path =
        if locale == source_locale
          relative_path
        else
          relative_path.sub(/\A#{Regexp.escape(source_locale)}\//, "#{locale}/")
        end

      source_path = File.join(screenshots_root(config), relative_path)
      destination_path = File.join(screenshots_root(config), locale_relative_path)
      UI.user_error!("Missing screenshot asset #{source_path}") unless File.exist?(source_path)
      FileUtils.mkdir_p(File.dirname(destination_path))
      next if locale == source_locale

      FileUtils.cp(source_path, destination_path)
    end
  end

  source_files.flat_map do |relative_path|
    target_locales.map do |locale|
      if locale == source_locale
        relative_path
      else
        relative_path.sub(/\A#{Regexp.escape(source_locale)}\//, "#{locale}/")
      end
    end
  end
end

def normalized_release_mode(raw_mode)
  case raw_mode.to_s
  when "validate", "testflight", "app-store"
    raw_mode.to_s
  else
    UI.user_error!("Unsupported release mode #{raw_mode.inspect}. Use validate, testflight, or app-store.")
  end
end

def release_notes_file(config)
  File.join(metadata_root(config), default_locale(config), "release_notes.txt")
end

def release_notes_text(config)
  path = release_notes_file(config)
  UI.user_error!("Missing release notes at #{path}") unless File.exist?(path)
  contents = File.read(path).strip
  UI.user_error!("Release notes at #{path} are empty") if contents.empty?
  contents
end

def app_store_connect_api_key_from_env
  key_id = ENV["FORGE_ASC_KEY_ID"].to_s
  issuer_id = ENV["FORGE_ASC_ISSUER_ID"].to_s
  key_path = ENV["FORGE_ASC_KEY_PATH"].to_s
  key_content_base64 = ENV["FORGE_ASC_KEY_CONTENT_BASE64"].to_s

  UI.user_error!("FORGE_ASC_KEY_ID is required") if key_id.empty?
  UI.user_error!("FORGE_ASC_ISSUER_ID is required") if issuer_id.empty?

  key_content =
    if key_content_base64.empty?
      if key_path.empty?
        UI.user_error!("Provide either FORGE_ASC_KEY_PATH or FORGE_ASC_KEY_CONTENT_BASE64")
      end
      UI.user_error!("ASC key file not found at #{key_path}") unless File.exist?(key_path)
      File.read(key_path)
    else
      Base64.decode64(key_content_base64)
    end

  app_store_connect_api_key(
    key_id: key_id,
    issuer_id: issuer_id,
    key_content: key_content,
    duration: 1200,
    in_house: false
  )
end

def verify_app_store_connect_app!(config:)
  return nil if ENV["FORGE_RELEASE_SKIP_REMOTE_VALIDATION"] == "1"
  app_identifier = config.dig(:app, :primary_bundle_id)
  app = Spaceship::ConnectAPI.get_apps(filter: { bundleId: app_identifier }, limit: 1).first
  UI.user_error!("No App Store Connect app record found for #{app_identifier}") unless app
  app
end

def read_build_setting(target_name:, key:)
  command = [
    "xcodebuild",
    "-project", Shellwords.escape(xcode_project_path),
    "-target", Shellwords.escape(target_name),
    "-showBuildSettings"
  ].join(" ")
  output = Actions.sh(command, log: false)
  setting_pattern = /^\s*#{Regexp.escape(key)}\s*=/
  line = output.lines.find { |current| current.match?(setting_pattern) }
  UI.user_error!("Could not resolve #{key} for target #{target_name}") unless line
  line.split("=", 2).last.to_s.strip
end

def verify_project_bundle_ids!(config)
  expected = {
    "ForgeCompanion" => config.dig(:app, :primary_bundle_id),
    "ForgeWatch Watch App" => config.dig(:app, :watch_bundle_ids, 0),
    "ForgeWatchExtension" => config.dig(:app, :watch_bundle_ids, 1)
  }

  expected.each do |target_name, bundle_id|
    actual = read_build_setting(target_name: target_name, key: "PRODUCT_BUNDLE_IDENTIFIER")
    UI.user_error!("Target #{target_name} bundle id mismatch: expected #{bundle_id}, got #{actual}") unless actual == bundle_id
  end
end

def validate_metadata!(config:, mode:)
  locale_root = File.join(metadata_root(config), default_locale(config))
  required_files = %w[
    description.txt
    subtitle.txt
    keywords.txt
    promotional_text.txt
    support_url.txt
    marketing_url.txt
    privacy_url.txt
    release_notes.txt
  ]

  required_files.each do |file_name|
    path = File.join(locale_root, file_name)
    UI.user_error!("Missing required metadata file #{path}") unless File.exist?(path)
    contents = File.read(path).strip
    UI.user_error!("Metadata file #{path} is empty") if contents.empty?
    if %w[support_url.txt marketing_url.txt privacy_url.txt].include?(file_name)
      if contents.start_with?("REPLACE_WITH_") || contents.include?("TODO")
        UI.user_error!("Replace placeholder value in #{path} before publishing")
      end
    end
  end

  upload_screenshots = mode == "app-store" && config.dig(:metadata, :upload_screenshots_for_app_store) == true
  screenshot_files = []
  if upload_screenshots
    screenshot_files = mirror_screenshots_for_locales!(config)
    screenshot_files.each do |relative_path|
      full_path = File.join(screenshots_root(config), relative_path)
      UI.user_error!("Missing screenshot asset #{full_path}") unless File.exist?(full_path)
    end
  end

  {
    locale: default_locale(config),
    metadata_root: metadata_root(config),
    upload_screenshots: upload_screenshots,
    screenshot_locales: screenshot_target_locales(config),
    screenshot_files: screenshot_files
  }
end

def validate_release_inputs!(config:, mode:, require_api_key:)
  verify_project_bundle_ids!(config)
  metadata_state = validate_metadata!(config: config, mode: mode)
  app_store_connect_api_key_from_env if require_api_key && ENV["FORGE_RELEASE_SKIP_REMOTE_VALIDATION"] != "1"
  metadata_state
end

def ci_uses_fastlane_setup?
  return false unless ENV["CI"]

  ENV["FORGE_IOS_SKIP_FASTLANE_SETUP_CI"] != "1"
end

def prepare_artifact_dir(raw_path, mode:)
  return raw_path if raw_path && !raw_path.to_s.strip.empty? && FileUtils.mkdir_p(raw_path)

  timestamp = Time.now.utc.strftime("%Y%m%d-%H%M%S")
  marketing_version = load_release_config.dig(:version, :marketing).to_s
  artifact_dir = File.join(release_root, ".artifacts", "releases", "#{mode}-v#{marketing_version}-#{timestamp}")
  FileUtils.mkdir_p(artifact_dir)
  artifact_dir
end

def increment_release_versions!(config)
  marketing_version = config.dig(:version, :marketing).to_s
  UI.user_error!("release.version.marketing must be set in #{release_config_path}") if marketing_version.empty?
  increment_version_number(
    version_number: marketing_version,
    xcodeproj: xcode_project_path
  )
  increment_build_number(xcodeproj: xcode_project_path)
end

def current_build_number
  project_dir = File.dirname(xcode_project_path)
  command = "cd #{Shellwords.escape(project_dir)} && xcrun agvtool what-version -terse"
  Actions.sh(command, log: false).strip
rescue StandardError
  info_plist_path = File.join(project_dir, "ForgeCompanion", "Info.plist")
  UI.important("Falling back to #{info_plist_path} for CFBundleVersion because agvtool is unavailable")
  Actions.sh("/usr/libexec/PlistBuddy -c 'Print :CFBundleVersion' #{Shellwords.escape(info_plist_path)}", log: false).strip
end

def release_target_bundle_ids
  {
    "ForgeCompanion" => read_build_setting(target_name: "ForgeCompanion", key: "PRODUCT_BUNDLE_IDENTIFIER"),
    "ForgeWatch Watch App" => read_build_setting(target_name: "ForgeWatch Watch App", key: "PRODUCT_BUNDLE_IDENTIFIER"),
    "ForgeWatchExtension" => read_build_setting(target_name: "ForgeWatchExtension", key: "PRODUCT_BUNDLE_IDENTIFIER"),
    "ForgeScreenTimeReportExtension" => read_build_setting(target_name: "ForgeScreenTimeReportExtension", key: "PRODUCT_BUNDLE_IDENTIFIER")
  }
end

def provisioning_profile_directory
  configured = ENV["FORGE_IOS_PROVISIONING_PROFILE_DIR"].to_s.strip
  return configured unless configured.empty?

  File.expand_path("~/Library/MobileDevice/Provisioning Profiles")
end

def provisioning_profile_bundle_id(plist)
  application_identifier = plist.dig("Entitlements", "application-identifier").to_s
  _team_id, bundle_id = application_identifier.split(".", 2)
  bundle_id.to_s
end

def installed_provisioning_profiles
  profile_dir = provisioning_profile_directory
  return [] unless Dir.exist?(profile_dir)

  Dir.glob(File.join(profile_dir, "*.mobileprovision")).sort.filter_map do |path|
    decoded = Actions.sh("security cms -D -i #{Shellwords.escape(path)}", log: false)
    plist = CFPropertyList.native_types(CFPropertyList::List.new(data: decoded).value)
    bundle_id = provisioning_profile_bundle_id(plist)
    next if bundle_id.empty?

    {
      path: path,
      uuid: plist["UUID"].to_s,
      name: plist["Name"].to_s,
      bundle_id: bundle_id,
      team_ids: Array(plist["TeamIdentifier"]).map(&:to_s),
      get_task_allow: plist.dig("Entitlements", "get-task-allow") == true,
      provisioned_devices: Array(plist["ProvisionedDevices"]).map(&:to_s)
    }
  rescue StandardError => error
    UI.important("Skipping unreadable provisioning profile #{path}: #{error.message}")
    nil
  end
end

def app_store_profile?(profile)
  profile[:get_task_allow] == false && profile[:provisioned_devices].empty?
end

def provisioning_profile_matches_bundle_id?(profile, bundle_id)
  File.fnmatch(profile[:bundle_id], bundle_id)
end

def select_release_profile_for_bundle_id(bundle_id, profiles)
  exact_distribution = profiles.find { |profile| profile[:bundle_id] == bundle_id && app_store_profile?(profile) }
  return exact_distribution if exact_distribution

  wildcard_distribution = profiles.find do |profile|
    profile[:bundle_id].include?("*") && app_store_profile?(profile) && provisioning_profile_matches_bundle_id?(profile, bundle_id)
  end
  return wildcard_distribution if wildcard_distribution

  exact_any = profiles.find { |profile| profile[:bundle_id] == bundle_id }
  return exact_any if exact_any

  profiles.find do |profile|
    profile[:bundle_id].include?("*") && provisioning_profile_matches_bundle_id?(profile, bundle_id)
  end
end

def configure_manual_release_signing_if_available!
  return nil if ENV["FORGE_IOS_SIGNING_KEYCHAIN_PATH"].to_s.strip.empty?

  profiles = installed_provisioning_profiles
  UI.user_error!("CI signing assets were configured, but no provisioning profiles were installed in #{provisioning_profile_directory}.") if profiles.empty?

  bundle_ids = release_target_bundle_ids
  selected_profiles = {}
  profile_names_by_bundle_id = {}

  bundle_ids.each do |target_name, bundle_id|
    profile = select_release_profile_for_bundle_id(bundle_id, profiles)
    UI.user_error!("No installed provisioning profile matches bundle id #{bundle_id} for target #{target_name}.") unless profile
    UI.user_error!("Provisioning profile #{profile[:name]} for #{bundle_id} is not a distribution/App Store profile.") unless app_store_profile?(profile)

    selected_profiles[target_name] = profile
    profile_names_by_bundle_id[bundle_id] = profile[:name]
  end

  update_code_signing_settings(
    use_automatic_signing: false,
    path: xcode_project_path,
    team_id: ENV.fetch("FORGE_APPLE_TEAM_ID", "KZ65F7924F"),
    code_sign_identity: "Apple Distribution",
    build_configurations: ["Release"],
    sdk: "iphoneos*",
    targets: selected_profiles.keys
  )

  selected_profiles.each do |target_name, profile|
    update_project_provisioning(
      xcodeproj: xcode_project_path,
      target_filter: "^#{Regexp.escape(target_name)}$",
      build_configuration: "Release",
      profile: profile[:path],
      code_signing_identity: "Apple Distribution"
    )
  end

  {
    signingStyle: "manual",
    provisioningProfiles: profile_names_by_bundle_id,
    signingCertificate: "Apple Distribution",
    teamID: ENV.fetch("FORGE_APPLE_TEAM_ID", "KZ65F7924F")
  }
end

def build_release_archive!(artifact_dir:, archive_path:, marketing_version:, bump_build_number:)
  export_options = configure_manual_release_signing_if_available!
  build_ios_app(
    project: xcode_project_path,
    scheme: scheme_name,
    configuration: "Release",
    clean: true,
    export_method: "app-store",
    archive_path: archive_path,
    output_directory: artifact_dir,
    output_name: "ForgeCompanion-#{marketing_version}.ipa",
    include_symbols: true,
    include_bitcode: false,
    disable_xcpretty: true,
    xcargs: "-allowProvisioningUpdates",
    export_xcargs: "-allowProvisioningUpdates",
    export_team_id: ENV.fetch("FORGE_APPLE_TEAM_ID", "KZ65F7924F"),
    export_options: export_options,
    skip_profile_detection: !export_options.nil?
  )
end

def write_release_summary(
  artifact_dir:,
  mode:,
  config:,
  archive_path:,
  ipa_path:,
  build_number:,
  metadata_state:,
  uploaded:,
  submitted_for_review:
)
  summary = {
    mode: mode,
    app_name: config.dig(:app, :name),
    bundle_id: config.dig(:app, :primary_bundle_id),
    marketing_version: config.dig(:version, :marketing).to_s,
    build_number: build_number.to_s,
    archive_path: archive_path,
    ipa_path: ipa_path,
    metadata_root: metadata_state[:metadata_root],
    locale: metadata_state[:locale],
    uploaded: uploaded,
    submitted_for_review: submitted_for_review,
    generated_at: Time.now.utc.iso8601
  }
  File.write(File.join(artifact_dir, "release-summary.json"), JSON.pretty_generate(summary))
end
